# Auto-detect text files and normalize line endings
* text=auto

# Python files - LF
*.py text eol=lf

# JSON and YAML - LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Markdown - LF
*.md text eol=lf

# Windows batch files - CRLF
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.zip binary
